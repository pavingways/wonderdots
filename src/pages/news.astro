---
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";
import contentAssets from "../../.astro/content-assets.mjs";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import { getFormattedDate } from "@utils/all.js";

// Filter news entries with 'draft: false' & date before current date
const publishedNewsEntries = await getCollection("news", ({ data }) => {
  return !data.draft && data.publishDate < new Date();
});

// Sort content entries by publication date
publishedNewsEntries.sort(function (a, b) {
  return b.data.publishDate.valueOf() - a.data.publishDate.valueOf();
});

// Normalize entries so `image.src` is always a string (helps the `Picture` component typings)
type RawEntry = (typeof publishedNewsEntries)[number];
type NormalizedEntry = Omit<RawEntry, "data"> & {
  data: Omit<RawEntry["data"], "image"> & { image: { src: string; alt: string } };
};

const normalizedPublishedNewsEntries: NormalizedEntry[] = publishedNewsEntries.map((entry) => {
  const image = entry.data.image || {};
  let resolvedSrc = image.src;

  // Handle content image placeholders like "__ASTRO_IMAGE_./images/xyz.jpg"
  // by resolving them against the generated content-assets map.
  if (typeof resolvedSrc === "string" && resolvedSrc.startsWith("__ASTRO_IMAGE_")) {
    const filePath = resolvedSrc.replace("__ASTRO_IMAGE_", "");
    const match = Array.from(contentAssets.entries()).find(([k]) => k.startsWith(filePath));
    if (match) {
      const imported = match[1];
      resolvedSrc = imported && typeof imported === "object" && typeof imported.src === "string" ? imported.src : imported;
    }
  }

  return {
    ...entry,
    data: {
      ...entry.data,
      image: {
        ...image,
        src: resolvedSrc,
      },
    },
  };
});
---

<Layout title="News">
  <Container>
    <Sectionhead>
      <Fragment slot="title">News und Hintergründe</Fragment>
      <Fragment slot="desc">
        Aktuelle Neuigkeiten und Background-Infos zu unseren Aktivitäten bei Wonder Dots.
      </Fragment>
    </Sectionhead>
    <main class="mt-16">
      <ul class="grid gap-16 max-w-4xl mx-auto">
        {
          normalizedPublishedNewsEntries.map((newsPostEntry, index) => {
            // Resolve a usable image value for the template.
            const rawImage = newsPostEntry.data.image;
            const candidate = rawImage && (rawImage.src ?? rawImage);

            const allowedExt = ["jpg","jpeg","png","tiff","webp","gif","svg","avif"];
            let usePicture = false;
            let pictureSrc = candidate;

            if (typeof candidate === "string") {
              const ext = candidate.split("?")[0].split(".").pop()?.toLowerCase();
              if (allowedExt.includes(ext)) usePicture = true;
            } else if (candidate && typeof candidate === "object") {
              const s = candidate.src ?? candidate.default ?? null;
              if (typeof s === "string") {
                const clean = s.split("?")[0];
                const ext = clean.split(".").pop()?.toLowerCase();

                // Avoid passing raw /@fs/ filesystem paths to `Picture` (not supported).
                const isFsPath = s.startsWith("/@fs/");

                // Prefer a usable import/default URL when available; otherwise fall back to <img>.
                if (allowedExt.includes(ext) && !isFsPath) {
                  usePicture = true;
                  pictureSrc = candidate.default ?? candidate.src ?? s;
                } else if (allowedExt.includes(ext) && isFsPath && candidate.default && typeof candidate.default === 'string' && !candidate.default.startsWith('/@fs/')) {
                  usePicture = true;
                  pictureSrc = candidate.default;
                } else {
                  // Use the string (for <img>) if we can't provide a safe value to Picture
                  pictureSrc = s;
                }
              }
            }

            return (
            <li>
              <a href={`/news/${newsPostEntry.id}`}>
                <div class="grid md:grid-cols-2 gap-5 md:gap-10 items-center">
                  {
                    usePicture
                      ? (
                        <Picture
                          src={pictureSrc}
                          alt={newsPostEntry.data.image.alt}
                          sizes="(max-width: 800px) 100vw, 800px"
                          width={800}
                          height={600}
                          loading={index <= 2 ? "eager" : "lazy"}
                          decoding={index <= 2 ? "sync" : "async"}
                          class="w-full rounded-md object-cover object-center bg-white"
                        />
                      )
                      : (
                        <img
                          src={typeof pictureSrc === 'object' ? (pictureSrc.src ?? pictureSrc.default ?? '') : (pictureSrc ?? '')}
                          alt={newsPostEntry.data.image.alt}
                          loading={index <= 2 ? "eager" : "lazy"}
                          decoding={index <= 2 ? "sync" : "async"}
                          class="w-full rounded-md object-cover object-center bg-white"
                        />
                      )
                  }
                  <div>
                    <span class="text-blue-400 uppercase tracking-wider text-sm font-medium">
                      {newsPostEntry.data.category}
                    </span>

                    <h2 class="text-3xl font-semibold leading-snug tracking-tight mt-1 ">
                      {newsPostEntry.data.title}
                    </h2>

                    <div class="flex gap-2 mt-3">
                      <!--<span class="text-gray-400">-->
                      <!--  {newsPostEntry.data.author}-->
                      <!--</span>-->
                      <!--<span class="text-gray-400">• </span>-->
                      <time
                        class="text-gray-400"
                        datetime={newsPostEntry.data.publishDate.toISOString()}>
                        {getFormattedDate(newsPostEntry.data.publishDate)}
                      </time>
                    </div>
                  </div>
                </div>
              </a>
            </li>
            )
          })
        }
      </ul>
    </main>
  </Container>
</Layout>
